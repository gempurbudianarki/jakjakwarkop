generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  ADMIN
}

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  image         String?
  role          Role      @default(USER)
  points        Int       @default(0)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  checkIns CheckIn[]
  photos   Photo[]
  accounts Account[]
  sessions Session[]
}

model Warkop {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  latitude    Float
  longitude   Float
  address     String   @db.Text
  phone       String?
  image       String?
  facilities  Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checkIns CheckIn[]
  photos   Photo[]
}

model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  warkopId  String
  points    Int      @default(10)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  warkop Warkop @relation(fields: [warkopId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([warkopId])
  @@index([userId, warkopId])
}

model Photo {
  id           String      @id @default(cuid())
  userId       String
  warkopId     String
  url          String
  caption      String?     @db.Text
  status       PhotoStatus @default(PENDING)
  aiModerated  Boolean     @default(false)
  rejectionMsg String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  warkop Warkop @relation(fields: [warkopId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([warkopId])
  @@index([status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}
